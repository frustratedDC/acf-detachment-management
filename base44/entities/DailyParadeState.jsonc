        "Absent",
        "Excused"
      ],
      "description": "Attendance status"
    }
  },
  "required": [
    "Date",
    "UserPNumber",
    "AttendanceStatus"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "data.AccessLevel": {
          "$gte": 1
        }
      }
    },
