{
  "name": "CalendarEvent",
  "type": "object",
  "properties": {
    "Title": {
      "type": "string",
      "description": "Event title"
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "Event date"
    },
    "EndDate": {
      "type": "string",
      "format": "date",
      "description": "End date (for multi-day events)"
    },
    "EventType": {
      "type": "string",
      "enum": [
        "Training Night",
        "Camp",
        "Competition",
        "Admin",
        "Other"
      ],
      "default": "Training Night"
    },
    "Notes": {
      "type": "string",
      "description": "Event notes"
    },
    "IsTrainingNight": {
      "type": "boolean",
      "default": false,
      "description": "Whether this closes the detachment for a training night"
    },
    "AvailabilityDeadline": {
      "type": "string",
      "format": "date",
      "description": "Deadline for staff to submit availability"
    },
    "Location": {
      "type": "string"
    },
    "CreatedByPNumber": {
      "type": "string"
    },
    "ComplianceStatus": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "amber"
      ],
      "description": "Manual override for compliance status"
    },
    "StaffOnly": {
      "type": "boolean",
      "default": false,
      "description": "If true, only Adult Instructors (L3+) can see this event"
    },
    "FullPrice": {
      "type": "number",
      "description": "Standard full price for this event (optional)"
    },
    "FSMPrice": {
      "type": "number",
      "description": "Free School Meals / subsidized price for this event (optional)"
    },
    "AdultPrice": {
      "type": "number",
      "description": "Price applicable to adult staff attendees (optional)"
    },
    "GeneratedFromPlan": {
      "type": "boolean",
      "default": false,
      "description": "True if this event was generated via the Training Plan workflow rather than manually"
    }
  },
  "required": [
    "Title",
    "Date",
    "EventType"
  ]
}