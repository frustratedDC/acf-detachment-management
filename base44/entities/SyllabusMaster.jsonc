{
  "name": "SyllabusMaster",
  "type": "object",
  "properties": {
    "LessonCode": {
      "type": "string",
      "description": "Primary key for the lesson"
    },
    "StarLevel": {
      "type": "string",
      "enum": [
        "Basic",
        "1 Star",
        "2 Star",
        "3 Star",
        "4 Star"
      ],
      "description": "Star level for the lesson"
    },
    "SubjectName": {
      "type": "string",
      "description": "Subject category"
    },
    "LessonName": {
      "type": "string",
      "description": "Name of the lesson"
    },
    "IsMandatory": {
      "type": "boolean",
      "default": false,
      "description": "Whether the lesson is mandatory"
    },
    "GrantsQualification": {
      "type": "string",
      "description": "Optional: qualification granted on completion e.g. JCIC, SCIC"
    }
  },
  "required": [
    "LessonCode",
    "StarLevel",
    "SubjectName",
    "LessonName"
  ]
}