{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "DetachmentID": {
      "type": "string",
      "description": "Tenant identifier this user belongs to, synced from their linked PersonnelManager record. Used by RLS to scope data to their own detachment."
    }
  },
  "required": [
    "role"
  ]
}